{
  "expo": {
    "name": "SpotOn",
    "slug": "SpotOn-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spotonfrontend",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.mklshane.SpotOn-frontend"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF8A4C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mklshane.SpotOnfrontend"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF8A4C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SpotOn to use your camera to capture the skin spot for triage."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SpotOn to access your photos to upload a skin spot."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "SpotOn uses your camera to detect and capture the skin spot for triage.",
          "enableFrameProcessors": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
